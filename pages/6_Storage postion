import pandas as pd
import os
import tkinter as tk
from tkinter import filedialog, messagebox

def convert_data_file(data_file_path, output_file_path):
    try:
        # 1. 파일 로드
        data_df = pd.read_csv(data_file_path)

        # 2. 파일명에서 ChipPlateID 추출
        chip_plate_id = os.path.splitext(os.path.basename(data_file_path))[0]

        # 3. 새로운 데이터프레임 생성
        # 주의: pandas는 중복된 컬럼명(Well)이 있을 때 두 번째 컬럼을 'Well.1'로 자동 변경합니다.
        converted_result_df = pd.DataFrame({
            'SamplePlate': data_df['SamplePlate'],
            'SamplePosition': data_df['Well'],
            'Product ID': data_df['Product ID'],
            'ChipPlateID': data_df['ChipPlate'],
            'ChipPlatePosition': data_df['Well.1'],
            'StoreTubeID': chip_plate_id + '_' + data_df['Well.1'].astype(str),
            'MG ID': data_df['MG ID'],  
        })

        # 4. 결과 저장
        converted_result_df.to_csv(output_file_path, index=False, encoding='utf-8-sig')
        messagebox.showinfo("완료", f"파일 변환 및 저장이 완료되었습니다.\n저장 경로: {output_file_path}")
        
    except KeyError as e:
        messagebox.showerror("오류", f"원본 CSV 파일에 필수 컬럼이 누락되었습니다.\n누락된 컬럼: {e}")
    except Exception as e:
        messagebox.showerror("오류", f"알 수 없는 오류가 발생했습니다:\n{e}")

def select_files():
    input_file_path = filedialog.askopenfilename(title="Select the input CSV file", filetypes=[("CSV files", "*.csv")])
    if not input_file_path:
        return

    output_file_path = filedialog.asksaveasfilename(title="Save the output CSV file", defaultextension=".csv", filetypes=[("CSV files", "*.csv")])
    if not output_file_path:
        return

    convert_data_file(input_file_path, output_file_path)

# UI 초기화
root = tk.Tk()
root.title("Storage Position 변경기")
root.geometry("420x220")

usage_text = (
    "1. Chip 실험 Work에서 Chip Plate Export 파일(CSV)을 업로드 합니다.\n"
    "2. 변환된 파일을 저장할 위치와 이름을 지정해 줍니다."
)
tk.Label(root, text=usage_text, justify="left").pack(pady=15)
tk.Label(root, text="파일을 선택하려면 아래 버튼을 클릭하세요.").pack(pady=5)

select_button = tk.Button(root, text="파일 선택 및 변환", command=select_files, width=20, height=2)
select_button.pack(pady=10)

root.mainloop()
